<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:drawingapp.net.ViewModels"
             xmlns:models="using:drawingapp.net.Models"
             x:Class="drawingapp.net.Views.ToolPanel"
             x:DataType="vm:DrawingCanvasViewModel">
    
    <Border Background="#FAFAFA"
            BorderBrush="#E0E0E0"
            BorderThickness="0,0,1,0"
            Padding="8">
        <Border.Styles>
            <Style Selector="ToggleButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="4"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            
            <Style Selector="ToggleButton:checked">
                <Setter Property="Background" Value="#E3F2FD"/>
                <Setter Property="BorderBrush" Value="#1976D2"/>
            </Style>
            
            <Style Selector="ToggleButton:pointerover">
                <Setter Property="Background" Value="#F0F0F0"/>
            </Style>
            
            <Style Selector="ToggleButton:checked:pointerover">
                <Setter Property="Background" Value="#BBDEFB"/>
            </Style>
        </Border.Styles>
        
        <StackPanel Orientation="Vertical" Spacing="4">
            
            <ToggleButton Width="48" Height="48"
                          IsChecked="{Binding CurrentTool,
                                     Converter={x:Static vm:ToolConverter.Instance},
                                     ConverterParameter={x:Static models:Tool.Pen}}"
                          ToolTip.Tip="펜 (P)">
                <TextBlock Text="✏️" FontSize="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </ToggleButton>
            <ToggleButton Width="48" Height="48"
                          IsChecked="{Binding CurrentTool,
                                    Converter={x:Static vm:ToolConverter.Instance},
                                    ConverterParameter={x:Static models:Tool.Eraser}}"
                          ToolTip.Tip="지우개 (E)">
                <TextBlock Text="🧹" FontSize="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </ToggleButton>
            
            <Separator Margin="4,8"/>
            
            <ItemsControl ItemsSource="{Binding PaletteColors}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" MaxWidth="48"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="20" Height="20"
                                Margin="2"
                                Padding="0"
                                CornerRadius="4"
                                Command="{Binding $parent[ItemsControl].((vm:DrawingCanvasViewModel)DataContext).SelectColorCommand}"
                                CommandParameter="{Binding}">
                            <Button.Background>
                                <SolidColorBrush Color="{Binding}"/>
                            </Button.Background>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
           
            <Separator Margin="4,8"/>
            
            <StackPanel Spacing="4">
                <TextBlock Text="굵기" FontSize="11"
                           Foreground="#666"
                           HorizontalAlignment="Center"/>
                <Slider Minimum="1" Maximum="30"
                        Value="{Binding CurrentThickness}"
                        Orientation="Vertical"
                        Height="100"
                        HorizontalAlignment="Center"/>
                
                <TextBlock Text="{Binding CurrentThickness, StringFormat='{}{0:F0}px'}"
                           FontSize="11"
                           Foreground="#666"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
    
</UserControl>
